---
import Base from '../layouts/Base.astro';
---

<Base>
  <!-- Hero -->
  <header class="hero container">
    <span class="hero-badge">✦ Free to try, no signup</span>
    <h1>
      A cabinet of<br />
      <span class="gradient-text">curiosities.</span>
    </h1>
    <p>
      LiLan.io is a growing collection of free, fun things to try,
      from personality tests to whatever comes next.
      Each one lives at its own corner of the web:
      <code>name.lilan.io</code>
    </p>
    <div class="hero-actions">
      <a href="#curiosities" class="btn btn-primary">Explore curiosities</a>
      <a href="#how" class="btn btn-ghost">How it works</a>
    </div>
  </header>

  <!-- Curiosities grid -->
  <section id="curiosities">
    <div class="container">
      <div class="section-head">
        <h2>The cabinet</h2>
        <p>We are just getting started. New curiosities land here as they are built.</p>
      </div>
      <div class="bento">
        <a
          href="https://testme.lilan.io/"
          class="card card-featured card-link"
          target="_blank"
          rel="noopener"
        >
          <span class="badge-live">Live</span>
          <div class="card-icon">🧭</div>
          <h3>Test yourself</h3>
          <p>
            A growing collection of quick, fun tests, from MBTI-style personality
            types to how old you really act, and more on the way. No accounts,
            no fuss, just answer and find out.
          </p>
          <span class="card-cta">Take a test at testme.lilan.io →</span>
        </a>
        <div class="card">
          <span class="badge-soon">Always</span>
          <div class="card-icon">⚡</div>
          <h3>Free &amp; instant</h3>
          <p>Every LiLan curiosity is free to use and built to load in a blink.</p>
        </div>
        <a
          href="https://fate.lilan.io/"
          class="card card-link"
          target="_blank"
          rel="noopener"
        >
          <span class="badge-live">Live</span>
          <div class="card-icon">🔮</div>
          <h3>What does fate say?</h3>
          <p>
            A fortune-telling curiosity that reads the signs and tells you
            what the future might hold. No accounts, no fuss, just ask and see.
          </p>
          <span class="card-cta">Read your fortune at fate.lilan.io →</span>
        </a>
        <div class="card card-slot">
          <p>Future curiosity slot<br /><strong>•</strong></p>
        </div>
        <div class="card card-slot">
          <p>Future curiosity slot<br /><strong>•</strong></p>
        </div>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section id="how">
    <div class="container">
      <div class="section-head">
        <h2>One domain, many curiosities</h2>
        <p>
          LiLan.io is the front door. Every curiosity gets its own subdomain,
          so you can bookmark exactly the one you love.
        </p>
      </div>
      <div class="subdomain-demo">
        <span class="pill"><strong>testme</strong>.lilan.io</span>
        <span class="pill"><strong>fate</strong>.lilan.io</span>
        <span class="pill"><strong>your-idea</strong>.lilan.io</span>
      </div>
    </div>
  </section>

</Base>
