---
import Base from '../layouts/Base.astro';
---

<Base>
  <!-- Hero -->
  <header class="hero container">
    <span class="hero-badge">✦ Free tools, no signup required</span>
    <h1>
      Simple tools for<br />
      <span class="gradient-text">everyday decisions.</span>
    </h1>
    <p>
      LiLan.io is home to a growing collection of free online tools.
      Each one lives at its own corner of the web:
      <code>tool.lilan.io</code>
    </p>
    <div class="hero-actions">
      <a href="#tools" class="btn btn-primary">Browse tools</a>
      <a href="#how" class="btn btn-ghost">How it works</a>
    </div>
  </header>

  <!-- Tools grid -->
  <section id="tools">
    <div class="container">
      <div class="section-head">
        <h2>The toolbox</h2>
        <p>We are just getting started. New tools land here as they are built.</p>
      </div>
      <div class="bento">
        <div class="card card-featured">
          <span class="badge-soon">In the works</span>
          <div class="card-icon">🛠️</div>
          <h3>First tool loading...</h3>
          <p>
            Our first tool is being designed right now. It will show up here
            with its own subdomain the moment it is ready. No paywalls, no accounts,
            just open it and use it.
          </p>
        </div>
        <div class="card">
          <span class="badge-soon">Soon</span>
          <div class="card-icon">⚡</div>
          <h3>Fast &amp; free</h3>
          <p>Every LiLan tool is free to use and built to load instantly.</p>
        </div>
        <div class="card card-slot">
          <p>Future tool slot<br /><strong>•</strong></p>
        </div>
        <div class="card card-slot">
          <p>Future tool slot<br /><strong>•</strong></p>
        </div>
        <div class="card card-slot">
          <p>Future tool slot<br /><strong>•</strong></p>
        </div>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section id="how">
    <div class="container">
      <div class="section-head">
        <h2>One domain, many tools</h2>
        <p>
          LiLan.io is the front door. Every tool gets its own subdomain,
          so you can bookmark exactly what you need.
        </p>
      </div>
      <div class="subdomain-demo">
        <span class="pill"><strong>tool-one</strong>.lilan.io</span>
        <span class="pill"><strong>tool-two</strong>.lilan.io</span>
        <span class="pill"><strong>your-idea</strong>.lilan.io</span>
      </div>
    </div>
  </section>

</Base>
